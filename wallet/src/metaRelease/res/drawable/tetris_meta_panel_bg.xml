<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#12070A0F" />
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="#3D20DFC8" />
        </shape>
    </item>
    <item android:left="-14dp" android:top="-14dp" android:right="92dp" android:bottom="128dp">
        <shape android:shape="oval">
            <gradient
                android:angle="35"
                android:centerColor="#10158A80"
                android:endColor="#00158A80"
                android:startColor="#03158A80" />
        </shape>
    </item>
    <item android:left="120dp" android:top="90dp" android:right="-28dp" android:bottom="-20dp">
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:centerColor="#10180E34"
                android:endColor="#00180E34"
                android:startColor="#03180E34" />
        </shape>
    </item>
</layer-list>
