<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/pincode_dialog_bg"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:id="@+id/fee_title"
        style="@style/PageTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:textSize="24sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/panel_bg"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/fee_description"
            style="@style/NormalText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.vergepay.wallet.ui.widget.AmountEditView
            android:id="@+id/fee_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/fee_cancel"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginRight="6dp"
            android:layout_weight="1"
            android:background="@drawable/intro_action_button_alt_bg"
            android:elevation="6dp"
            android:fontFamily="sans-serif-condensed"
            android:text="@string/button_cancel"
            android:textAllCaps="true"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/fee_default"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:layout_weight="1"
            android:background="@drawable/intro_action_button_alt_bg"
            android:elevation="6dp"
            android:fontFamily="sans-serif-condensed"
            android:text="@string/button_default"
            android:textAllCaps="true"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/fee_ok"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginLeft="6dp"
            android:layout_weight="1"
            android:background="@drawable/intro_action_button_bg"
            android:elevation="6dp"
            android:fontFamily="sans-serif-condensed"
            android:text="@string/button_ok"
            android:textAllCaps="true"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
