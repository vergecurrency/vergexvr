<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallet_screen_bg"
    tools:context=".ui.AddressRequestFragment">

    <ScrollView
        android:id="@+id/request_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:descendantFocusability="beforeDescendants"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingBottom="@dimen/activity_vertical_margin"
            android:paddingLeft="@dimen/activity_horizontal_margin"
            android:paddingRight="@dimen/activity_horizontal_margin"
            android:paddingTop="@dimen/activity_vertical_margin">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal" >
                
                <LinearLayout
                    android:id="@+id/request_address_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/request_address_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/NormalText"
                        android:textIsSelectable="true"
                        android:textSize="@dimen/receive_address"
                        tools:text="Fancy address label" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/request_address"
                            style="@style/SmallHelpText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:ellipsize="end"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:maxLines="1"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:scrollHorizontally="true"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:typeface="monospace"
                            tools:text="nUdHXBSBYQPJREXZMBUdu8ARnWM2mz3XQp" />

                        <ImageView
                            android:id="@+id/request_address_copy"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginLeft="8dp"
                            android:background="@drawable/account_nav_overflow_bg"
                            android:contentDescription="@string/action_copy"
                            android:padding="8dp"
                            android:src="@drawable/abc_ic_menu_copy_mtrl_am_alpha"
                            android:tint="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <RelativeLayout
                android:visibility="gone"
                android:id="@+id/public_key"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal" >

                <TextView
                    android:id="@+id/request_public_key_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:text="@string/receive_address_label"
                    android:textColor="@color/gray_54_sec_text_icons" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/request_public_key_label"
                    style="@style/NormalText"
                    android:typeface="monospace"
                    android:textSize="@dimen/receive_address"
                    tools:text="a751ca7296d1b20ea1d33cb10967f2f8\n01cc9ef42fd3a28057a3b72bab98e496" />

            </RelativeLayout>

            <LinearLayout
                android:id="@+id/request_qr_amount_section"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <ImageView
                    android:id="@+id/qr_code"
                    android:layout_width="@dimen/receive_qr_code_size"
                    android:layout_height="@dimen/receive_qr_code_size"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp"
                    android:padding="12dp"
                    tools:background="@color/gray_87_text"
                    android:background="@drawable/qr_surface_bg"
                    android:layout_marginLeft="@dimen/qr_code_margin"
                    android:layout_marginRight="@dimen/qr_code_margin" />

                <LinearLayout
                    android:id="@+id/request_amount_row"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.vergepay.wallet.ui.widget.AmountEditView
                        android:id="@+id/request_coin_amount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/view_previous_addresses"
                android:layout_width="220dp"
                android:layout_height="54dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:background="@drawable/intro_action_button_alt_bg"
                android:elevation="6dp"
                android:fontFamily="sans-serif-condensed"
                android:text="@string/view_previous_addresses"
                android:textAllCaps="true"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
