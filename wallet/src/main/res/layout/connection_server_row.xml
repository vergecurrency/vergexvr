<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/intro_action_button_alt_bg"
    android:gravity="center_vertical"
    android:minHeight="84dp"
    android:orientation="horizontal"
    android:paddingLeft="14dp"
    android:paddingTop="12dp"
    android:paddingRight="14dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingRight="12dp">

        <TextView
            android:id="@+id/connection_row_endpoint"
            style="@style/NormalText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/connection_row_summary"
            style="@style/SmallHelpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/connection_row_state"
            style="@style/SmallHelpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/accent_alt" />
    </LinearLayout>

    <Button
        android:id="@+id/connection_row_connect"
        style="@style/SendSecondaryActionButton"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:minWidth="92dp"
        android:text="@string/button_connect" />
</LinearLayout>
