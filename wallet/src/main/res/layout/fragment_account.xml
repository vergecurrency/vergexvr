<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/account_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallet_screen_bg"
    android:orientation="vertical"
    android:paddingTop="0dp">

    <LinearLayout
        android:id="@+id/account_nav_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/account_nav_bar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="6dp"
        android:paddingTop="8dp"
        android:paddingRight="6dp"
        android:paddingBottom="8dp">

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/nav_receive"
                    style="@style/NormalText"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:background="@drawable/account_nav_item_default_bg"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center"
                    android:minWidth="84dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:text="@string/wallet_title_request"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/nav_balance"
                    style="@style/NormalText"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:layout_marginLeft="6dp"
                    android:background="@drawable/account_nav_item_default_bg"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center"
                    android:minWidth="84dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:text="@string/wallet_title_balance"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/nav_send"
                    style="@style/NormalText"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:layout_marginLeft="6dp"
                    android:background="@drawable/account_nav_item_default_bg"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center"
                    android:minWidth="76dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:text="@string/wallet_title_send"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/nav_swap"
                    style="@style/NormalText"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:layout_marginLeft="6dp"
                    android:background="@drawable/account_nav_item_default_bg"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center"
                    android:minWidth="76dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:text="@string/wallet_title_swap"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/nav_games"
                    style="@style/NormalText"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:layout_marginLeft="6dp"
                    android:background="@drawable/account_nav_item_default_bg"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center"
                    android:minWidth="82dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:text="@string/wallet_title_games"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <ImageButton
            android:id="@+id/nav_overflow"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginLeft="6dp"
            android:background="@drawable/account_nav_overflow_bg"
            android:contentDescription="@string/action_settings"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/abc_ic_menu_overflow_material" />
    </LinearLayout>

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/primary_700" />

</LinearLayout>
