<resources>

    <style name="AppThemeNoTitleBar" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/primary_800</item>
        <item name="colorPrimaryDark">@color/primary_900</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@drawable/wallet_screen_bg</item>
        <item name="alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="android:alertDialogTheme">@style/AppAlertDialogTheme</item>
    </style>

    <style name="AppTheme" parent="Theme.AppCompat">
        <item name="colorPrimary">@color/primary_800</item>
        <item name="colorPrimaryDark">@color/primary_900</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@drawable/wallet_screen_bg</item>
        <item name="alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="android:alertDialogTheme">@style/AppAlertDialogTheme</item>
    </style>

    <style name="AppAlertDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/pincode_dialog_bg</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:buttonBarButtonStyle">@style/BorderlessButtonLink</item>
        <item name="buttonBarButtonStyle">@style/BorderlessButtonLink</item>
    </style>

    <!-- Special Button styles -->
    <style name="BorderlessButton">
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
    </style>

    <style name="BorderlessButtonLink" parent="BorderlessButton">
        <item name="android:textColor">@color/accent_alt</item>
    </style>

    <!-- Font icons -->
    <style name="FontIconBig" parent="NormalText">
        <item name="android:textSize">@dimen/font_icon_text_size</item>
        <item name="android:textColor">@color/font_icon_fg_color</item>
        <item name="android:background">@drawable/font_icon_bg</item>
        <item name="android:gravity">center_horizontal|center_vertical</item>
    </style>

    <!-- Generic text styles -->
    <style name="NormalText" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorLink">@color/accent_alt</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="SecondaryText" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="SmallHelpText" parent="SecondaryText">
        <item name="android:textSize">@dimen/caption</item>
    </style>

    <style name="ErrorText" parent="">
        <item name="android:textColor">@color/fg_error</item>
    </style>

    <style name="WarningText" parent="">
        <item name="android:textColor">@color/fg_warning</item>
    </style>

    <style name="OkText" parent="">
        <item name="android:textColor">@color/fg_ok</item>
    </style>

    <style name="SeedText" parent="">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/seed_text_size</item>
    </style>

    <style name="GenericCircle" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/generic_circle_text_size</item>
    </style>

    <style name="GenericCircleGreen" parent="GenericCircle">
        <item name="android:background">@drawable/generic_green_circle</item>
    </style>

    <style name="GenericCircleRed" parent="GenericCircle">
        <item name="android:background">@drawable/generic_red_circle</item>
    </style>

    <!-- PagerTabStrip style -->
    <style name="PagerTabStrip" parent="NormalText">
        <item name="android:background">@color/actionbar_bg</item>
        <item name="android:textColor">@color/actionbar_fg</item>
    </style>

    <!-- Widget amount style -->
    <style name="Amount" parent="NormalText">
        <item name="android:singleLine">true</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="AmountBig" parent="Amount">
        <item name="android:textSize">@dimen/amount_text_size_big</item>
    </style>
    <style name="AmountSmall" parent="Amount">
        <item name="android:textSize">@dimen/amount_text_size_small</item>
    </style>

    <style name="AmountSymbol" parent="SecondaryText">
        <item name="android:singleLine">true</item>
    </style>
    <style name="AmountSymbolBig" parent="AmountSymbol">
        <item name="android:textSize">@dimen/amount_symbol_text_size</item>
        <item name="android:singleLine">true</item>
    </style>
    <style name="AmountSymbolSmall" parent="AmountSymbol">
        <item name="android:textSize">@dimen/amount_text_size_small</item>
        <item name="android:singleLine">true</item>
    </style>

    <!-- Widget send output -->
    <style name="SendOutputTypeText" parent="NormalText">
        <item name="android:textColor">@color/accent_alt</item>
    </style>
    <style name="SendOutputAmount" parent="NormalText">
        <item name="android:textSize">@dimen/send_output_amount_text_size</item>
        <item name="android:singleLine">true</item>
    </style>

    <!-- Transaction row -->
    <style name="TransactionRowDirectionFontIcon" parent="SecondaryText">
        <item name="android:textSize">@dimen/transaction_row_direction_font_icon_size</item>
    </style>
    <style name="TransactionRowConfidenceFontIcon" parent="SecondaryText">
        <item name="android:textSize">@dimen/transaction_row_confirmations_font_icon_size</item>
    </style>
    <style name="TransactionRowMessageFontIcon" parent="SecondaryText">
        <item name="android:textSize">@dimen/transaction_row_message_font_icon_size</item>
    </style>
    <style name="TransactionRowDirectionText" parent="SecondaryText">
        <item name="android:textSize">@dimen/transaction_row_text_size_direction_text</item>
    </style>
    <style name="TransactionRowDate" parent="SecondaryText">
        <item name="android:textSize">@dimen/transaction_row_text_size_date</item>
    </style>
    <style name="AddressRowLabel" parent="NormalText">
        <item name="android:textSize">@dimen/row_text_size_label</item>
    </style>
    <style name="TransactionRowAmount" parent="Amount">
        <item name="android:textSize">@dimen/transaction_row_text_size_amount</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SectionTitleText" parent="SecondaryText">
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/accent_alt</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.16</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <style name="PageTitleText" parent="NormalText">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/accent_alt</item>
        <item name="android:textSize">22sp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- About Activity -->
    <style name="AppNameLong">
        <item name="android:textSize">@dimen/app_name_long</item>
    </style>

    <!-- Exchange row -->
    <style name="ExchangeRowSymbol" parent="FontIconBig">
        <item name="android:textSize">@dimen/exchange_row_symbol_text_size</item>
        <item name="android:singleLine">true</item>
    </style>
    <style name="ExchangeRowLabel" parent="NormalText">
        <item name="android:textSize">@dimen/exchange_row_text_size_label</item>
    </style>

    <style name="PincodeEditText" parent="Base.Widget.AppCompat.EditText">
        <item name="android:background">@drawable/pincode_slot_bg</item>
        <item name="android:inputType">numberPassword</item>
        <item name="android:maxLength">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:maxLines">1</item>
        <item name="android:textAlignment">center</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAppearance">@style/TextAppearance.AppCompat.Large</item>
    </style>

    <style name="RetroPopupMenu" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/retro_popup_menu_bg</item>
        <item name="android:dropDownHorizontalOffset">-8dp</item>
        <item name="android:dropDownVerticalOffset">6dp</item>
        <item name="dropDownListViewStyle">@style/RetroPopupMenuListView</item>
        <item name="android:textAppearanceLargePopupMenu">@style/RetroPopupMenuText</item>
        <item name="android:textAppearanceSmallPopupMenu">@style/RetroPopupMenuText</item>
        <item name="textAppearanceLargePopupMenu">@style/RetroPopupMenuText</item>
        <item name="textAppearanceSmallPopupMenu">@style/RetroPopupMenuText</item>
    </style>

    <style name="RetroPopupMenuText" parent="@style/TextAppearance.AppCompat.Body1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="RetroPopupMenuListView" parent="Widget.AppCompat.ListView.DropDown">
        <item name="android:listSelector">@drawable/drawer_item_selected_bg</item>
        <item name="android:divider">@android:color/transparent</item>
        <item name="android:dividerHeight">4dp</item>
    </style>

</resources>
