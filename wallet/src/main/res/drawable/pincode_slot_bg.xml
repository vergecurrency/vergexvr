<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#FF432A7E"
                android:startColor="#FF241A52" />
            <corners android:radius="18dp" />
            <stroke
                android:width="2dp"
                android:color="@color/accent_alt" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#CC1D1638"
                android:startColor="#E6251B4A" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/stroke_soft" />
        </shape>
    </item>
</selector>
