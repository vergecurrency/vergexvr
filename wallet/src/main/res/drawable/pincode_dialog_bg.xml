<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#040406" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#3AC7FFF2" />
        </shape>
    </item>
    <item android:left="-12dp" android:top="-18dp" android:right="120dp" android:bottom="180dp">
        <shape android:shape="oval">
            <gradient
                android:angle="35"
                android:centerColor="#18158A80"
                android:endColor="#00158A80"
                android:startColor="#03158A80" />
        </shape>
    </item>
    <item android:left="120dp" android:top="170dp" android:right="-30dp" android:bottom="-40dp">
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:centerColor="#22180E34"
                android:endColor="#00180E34"
                android:startColor="#04180E34" />
        </shape>
    </item>
</layer-list>
