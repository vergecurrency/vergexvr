<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="2dp" android:right="2dp" android:top="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#AAFF4FD8"
                android:startColor="#AA2FDBFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#FFEB5CFF"
                android:startColor="#FF26D8FF" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="#B3FFFFFF" />
        </shape>
    </item>
</layer-list>
