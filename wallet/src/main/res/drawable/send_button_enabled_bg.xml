<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="2dp" android:right="2dp" android:top="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#AA20DFC8"
                android:startColor="#AA6A37D6" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#FF20DFC8"
                android:startColor="#FF6E39E2" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="#B3FFFFFF" />
        </shape>
    </item>
</layer-list>
