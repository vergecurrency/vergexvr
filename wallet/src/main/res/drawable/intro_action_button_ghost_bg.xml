<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="2dp" android:right="2dp" android:top="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#6620DFC8"
                android:startColor="#66432A7B" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#3320DFC8"
                android:startColor="#55342866" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="#8845E3D0" />
        </shape>
    </item>
</layer-list>
