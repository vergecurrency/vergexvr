<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="@color/surface_card_alt"
                android:startColor="#2E1B5D" />
            <corners
                android:bottomLeftRadius="28dp"
                android:bottomRightRadius="28dp" />
            <stroke
                android:width="1dp"
                android:color="@color/stroke_glow" />
        </shape>
    </item>
    <item android:right="-40dp" android:top="-24dp">
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:centerColor="#66FF4FD8"
                android:endColor="#00FF4FD8"
                android:startColor="#10FF4FD8" />
        </shape>
    </item>
    <item android:left="-20dp" android:bottom="-30dp">
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:centerColor="#5530E3FF"
                android:endColor="#0030E3FF"
                android:startColor="#1030E3FF" />
        </shape>
    </item>
    <item android:left="100dp" android:bottom="-14dp" android:right="-20dp">
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:centerColor="#38FF9B54"
                android:endColor="#00FF9B54"
                android:startColor="#08FF9B54" />
        </shape>
    </item>
</layer-list>
